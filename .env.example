# Firebase web app config for Google sign-in.
#
# 1. Create a Firebase project: https://console.firebase.google.com
# 2. Add a Web App to it and copy the config values below.
# 3. In Authentication > Sign-in method, enable the "Google" provider.
# 4. In Authentication > Settings > Authorized domains, add "localhost" and
#    your GitHub Pages domain (e.g. "yourname.github.io"). Do NOT include the
#    protocol or port.
# 5. Copy this file to ".env.local" and fill in the values, then restart the
#    dev server.
#
# These values are safe to expose in a client app (the API key is not a secret).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# OpenAI key for "Bruh's Homework Help" (the AI tutor chat).
#
# IMPORTANT: this is a SECRET. It must NOT have a VITE_ prefix, or Vite would
# bundle it into the public client. It is only read on the server side:
#   - locally, by the /api/homework dev middleware in vite.config.js
#   - in production, by the api/homework.js serverless function (set these in
#     your host's env vars, e.g. Vercel/Netlify project settings)
# The browser only ever talks to /api/homework, never to OpenAI directly.
#
# (The placement test no longer needs OpenAI — it runs a deterministic,
# section-gated adaptive engine fully on-device.)
OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Only needed if the app is hosted somewhere that CAN'T run the serverless
# function (e.g. GitHub Pages). Point this at the full URL of your deployed
# homework function, e.g. https://your-proxy.vercel.app/api/homework.
# Leave blank to use the same-origin /api/homework endpoint.
VITE_HOMEWORK_API_URL=
